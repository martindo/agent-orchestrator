# =============================================================================
# Agent Orchestrator — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# =============================================================================

# ---- PostgreSQL ----
POSTGRES_USER=orchestrator
POSTGRES_PASSWORD=changeme
POSTGRES_DB=agent_orchestrator

# Connection string used by the application (host matches docker service name)
DATABASE_URL=postgresql://orchestrator:changeme@db:5432/agent_orchestrator

# ---- LLM Provider API Keys ----
AGENT_ORCH_OPENAI_API_KEY=
AGENT_ORCH_ANTHROPIC_API_KEY=
AGENT_ORCH_GOOGLE_API_KEY=
AGENT_ORCH_GROK_API_KEY=
